# ── LLM Observability Stack ──────────────────────────────────────
# Run ./setup.sh to generate this file interactively.

# Docker
COMPOSE_PROJECT_NAME=llm-stack
NETWORK_NAME=llm-proxy-net

# LLM Proxy
LLM_PROXY_PORT=4000
TRACE_EXPORTERS=phoenix
OTEL_PROJECT_NAME=llm-proxy
# OPIK_OTEL_ENDPOINT=http://opik-frontend:5173/api/v1/private/otel/v1/traces
# OPIK_API_KEY=
# OPIK_WORKSPACE=
# OPIK_OTEL_HEADERS=
# PHOENIX_COLLECTOR_ENDPOINT=http://phoenix:6006
# PHOENIX_API_KEY=
# PHOENIX_OTEL_HEADERS=

# mitmproxy
MITMPROXY_UI_PORT=8081
MITMPROXY_WEB_PASSWORD=mitmpass
# Stream SSE responses through mitmproxy without buffering (enables real-time streaming)
# Set to false to buffer all responses for full inspection in the mitmproxy UI
# MITMPROXY_STREAM_SSE=false

# Optional services (comma-separated: phoenix,claude-chat,claude-proxy,claude-code)
# COMPOSE_PROFILES=phoenix,claude-chat,claude-proxy,claude-code

# ── Optional: Claude services ────────────────────────────────────
# Required if chat, claude-api, or claude-code profiles are enabled.
# ANTHROPIC_API_KEY=

# API key for authenticating calls to the claude-sdk-proxy service (port 4100)
# CLAUDE_PROXY_API_KEY=

# Upstream base URL for claude-sdk-proxy
# docker-compose defaults this to the local llm-proxy so traces are captured automatically
# The app itself falls back to the direct Anthropic API when this is unset
# CLAUDE_PROXY_ANTHROPIC_BASE_URL=http://localhost:4000/anthropic

# Disable opik usage reporting
OPIK_USAGE_REPORT_ENABLED=false

# Enable input transformers in Claude SDK Proxy
# Comma separated built-in plugin names or file paths
# Built-ins are loaded from app/plugins/transform/<name>/
# Use full paths for custom plugins in the data dir
# CLAUDE_PROXY_PLUGINS_TRANSFORM="openfang,/data/custom-transformer.ts"
